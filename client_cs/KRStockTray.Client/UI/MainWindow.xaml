<Window x:Class="KRStockTray.Client.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False">

    <Border x:Name="RootBorder"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown"
            MouseRightButtonUp="RootBorder_MouseRightButtonUp"
            MouseEnter="RootBorder_MouseEnter"
            MouseLeave="RootBorder_MouseLeave"
            CornerRadius="6"
            Background="White"
            BorderBrush="#DDD"
            BorderThickness="1"
            Padding="6"
            Opacity="{Binding EffectiveOpacity}">

        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="1.0"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <ItemsControl ItemsSource="{Binding Quotes}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>

                        <!-- 종목명 -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding DisplaySymbol}"
                                   Foreground="Black"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center"/>

                        <!-- 현재가 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PriceText}"
                                   Foreground="Black"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>

                        <!-- 등락 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DiffText}"
                                   Foreground="{Binding DiffColor}"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>

                        <!-- 등락률 -->
                        <TextBlock Grid.Column="3"
                                   Text="{Binding PctText}"
                                   Foreground="{Binding DiffColor}"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>

                        <!-- 거래량 -->
                        <TextBlock Grid.Column="4"
                                   Text="{Binding Volume, StringFormat={}{0:N0}}"
                                   Foreground="Gray"
                                   FontFamily="Consolas"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>
