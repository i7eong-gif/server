<Window x:Class="KRStockTray.Client.UI.AddByCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="종목 추가"
        Width="300"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="12">
        <TextBlock Text="Market (KR / US)"/>
        <ComboBox x:Name="MarketBox"
                  SelectedIndex="0"
                  Margin="0,4,0,8">
            <ComboBoxItem Content="KR"/>
            <ComboBoxItem Content="US"/>
        </ComboBox>

        <TextBlock Text="Code"/>
        <TextBox x:Name="CodeBox"
                 Margin="0,4,0,12"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="추가"
                    Width="80"
                    Margin="0,0,6,0"
                    Click="Add_Click"/>
            <Button Content="취소"
                    Width="80"
                    Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
